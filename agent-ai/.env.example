# Server
PORT=5001
CLIENT_ORIGIN=http://localhost:5173
# Set true only behind a proxy that overwrites X-Forwarded-For.
TRUST_PROXY=false
MAX_UPLOAD_BYTES=10485760
DOCUMENT_TTL_MS=3600000

# Optional live AI. Local extractive RAG works without these values.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5
SERPAPI_KEY=
