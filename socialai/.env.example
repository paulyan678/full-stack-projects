# Core server settings
APP_ENV=development
PORT=8080
PUBLIC_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# Enable only behind a proxy that overwrites X-Forwarded-For.
TRUST_PROXY=false
# Generate with: openssl rand -base64 48
JWT_SECRET=
JWT_TTL=24h
MAX_UPLOAD_BYTES=26214400

# memory | file | elasticsearch
REPOSITORY_BACKEND=file
DATA_FILE=../data/socialai.json
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_INDEX_PREFIX=socialai

# local | gcs
MEDIA_BACKEND=local
MEDIA_DIRECTORY=../media
GCS_BUCKET=
# Optional outside GCE/GAE; on Google Cloud the metadata identity is used.
GCS_BEARER_TOKEN=

# local creates a credential-free SVG preview; openai calls the server-side API.
AI_IMAGE_BACKEND=local
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_BASE_URL=https://api.openai.com/v1

# Frontend (leave empty for the Vite/nginx same-origin proxy)
VITE_API_BASE_URL=
