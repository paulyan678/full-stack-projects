# Backend bind/public URLs. Android Emulator reaches the host as 10.0.2.2.
PORT=8080
PUBLIC_BASE_URL=http://10.0.2.2:8080

# For a physical device, use your computer's LAN address in both PUBLIC_BASE_URL
# and Android's SPOTIFY_API_BASE_URL Gradle property (the latter must end with /).
# SPOTIFY_API_BASE_URL=http://192.168.1.100:8080/
